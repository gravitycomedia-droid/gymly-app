rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users — same-gym read/write; role and gym_id are server-managed fields
    match /users/{uid} {
      allow read: if request.auth != null
                  && (
                    request.auth.uid == uid
                    ||
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.gym_id
                      == resource.data.gym_id
                  );

      allow create: if request.auth != null;

      allow update: if request.auth != null
                    && (
                      request.auth.uid == uid
                      ||
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.gym_id
                        == resource.data.gym_id
                    )
                    && !('role' in request.resource.data)
                    && !('gym_id' in request.resource.data);

      allow delete: if false;
    }

    // Gyms — authenticated users can read/write, public can read
    match /gyms/{gymId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Leads — public can create, authenticated gym staff can read/update
    match /leads/{leadId} {
      allow create: if true;
      allow read, update: if request.auth != null;
    }

    // Phase 3: Workout System
    match /workout_plans/{planId} {
      allow read, write: if request.auth != null;
    }
    
    match /workout_days/{dayId} {
      allow read, write: if request.auth != null;
    }
    
    match /workout_logs/{logId} {
      allow read, write: if request.auth != null;
    }
    
    match /progress_logs/{logId} {
      allow read, write: if request.auth != null;
    }
    
    match /soreness_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Phase 4: Payments & Invoicing
    match /payments/{paymentId} {
      allow read, write: if request.auth != null;
    }

    match /invoice_counter/{gymId} {
      allow read, write: if request.auth != null;
    }

    // Phase 4: Attendance
    match /attendance_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Phase 4: WhatsApp Logs
    match /whatsapp_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Phase 5: Message Retry Queue (Cloud Functions only, but allow read for dashboard)
    match /message_retry_queue/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Phase 5: Message Logs
    match /message_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Phase 6: Invoices
    match /invoices/{invoiceId} {
      allow read, write: if request.auth != null;
    }

    // Subscription System
    match /subscriptions/{gymId} {
      // Gym owner can read their own subscription; admin can read/write all
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/gyms/$(gymId)).data.owner_id == request.auth.uid);
    }

    match /billing/{gymId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/gyms/$(gymId)).data.owner_id == request.auth.uid);
    }

    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false; // managed via Firebase Console / server only
    }

    match /admin_logs/{logId} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update, delete: if false;
    }

    // Member Numbering System
    match /numbering_settings/{gymId} {
      allow read, write: if request.auth != null;
    }

    match /serial_counters/{docId} {
      allow read, write: if request.auth != null;
    }

    // Coupon Activation — owners read/write their gym's used coupon records
    match /used_coupons/{docId} {
      allow read, write: if request.auth != null;
    }

    // Kiosk Devices — authenticated owners manage devices; unauthenticated kiosks
    // need read access to pair (look up by pairingCode) and write to update status/lastSeen
    match /kiosk_devices/{deviceId} {
      allow read: if true;  // kiosk device needs to read to pair
      allow create: if request.auth != null;
      allow update: if true;  // kiosk updates lastSeen/status without auth session
      allow delete: if request.auth != null;
    }

    // Attendance Sessions — kiosk devices read/write without auth; owners read for analytics
    match /attendance_sessions/{sessionId} {
      allow read, write: if true;
    }

    // Access Denied Logs — kiosk writes, owners read
    match /access_denied_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if true;
    }

    // Coupons — server-only; never readable or writable by clients
    match /coupons/{code} {
      allow read, write: if false;
    }

    // Recycle bin — owner and manager in same gym can read; all writes server-only
    match /deleted_members/{gymId}/bin/{memberId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.gym_id == gymId
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           in ['owner', 'manager'];
      allow write: if false;
    }

    // Audit log — owner and manager read only; completely server-side writes
    match /audit_logs/{gymId}/events/{eventId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.gym_id == gymId
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           in ['owner', 'manager'];
      allow write: if false;
    }
  }
}
