rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users — authenticated users can read/write their own doc
    // and read other users in their gym
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Gyms — authenticated users can read/write
    match /gyms/{gymId} {
      allow read, write: if request.auth != null;
    }

    // Phase 3: Workout System
    match /workout_plans/{planId} {
      allow read, write: if request.auth != null;
    }
    
    match /workout_days/{dayId} {
      allow read, write: if request.auth != null;
    }
    
    match /workout_logs/{logId} {
      allow read, write: if request.auth != null;
    }
    
    match /progress_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Phase 4: Payments & Invoicing
    match /payments/{paymentId} {
      allow read, write: if request.auth != null;
    }

    match /invoice_counter/{gymId} {
      allow read, write: if request.auth != null;
    }

    // Phase 4: Attendance
    match /attendance_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Phase 4: WhatsApp Logs
    match /whatsapp_logs/{logId} {
      allow read, write: if request.auth != null;
    }
  }
}
