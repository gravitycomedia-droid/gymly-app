rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users — same-gym read/write; role and gym_id are server-managed fields
    match /users/{uid} {
      allow read: if request.auth != null
                  && (
                    request.auth.uid == uid
                    ||
                    request.auth.token.gym_id
                      == resource.data.gym_id
                  );

      allow create: if request.auth != null;

      allow update: if request.auth != null
                    && (
                      request.auth.uid == uid
                      ||
                      request.auth.token.gym_id
                        == resource.data.gym_id
                    )
                    && !('role' in request.resource.data)
                    && !('gym_id' in request.resource.data);

      allow delete: if false;
    }

    // Gyms — authenticated read; writes scoped to owner_id (H-3)
    match /gyms/{gymId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.owner_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.owner_id == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.owner_id == request.auth.uid;
    }

    // Leads — public can create with validated fields only; staff can read/update (L-2)
    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'phone', 'email', 'gym_id', 'created_at', 'message'])
        && request.resource.data.name is string && request.resource.data.name.size() < 100
        && request.resource.data.phone is string && request.resource.data.phone.size() < 100;
      allow read, update: if request.auth != null;
    }

    // Phase 3: Workout System
    match /workout_plans/{planId} {
      allow read, write: if request.auth != null;
    }

    match /workout_days/{dayId} {
      allow read, write: if request.auth != null;
    }

    match /workout_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    match /progress_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    match /soreness_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Phase 4: Payments — gym-isolated (H-4)
    match /payments/{paymentId} {
      allow read: if request.auth != null
        && request.auth.token.gym_id
           == resource.data.gym_id;
      allow create: if request.auth != null
        && request.resource.data.gym_id
           == request.auth.token.gym_id;
      allow update, delete: if request.auth != null
        && resource.data.gym_id
           == request.auth.token.gym_id;
    }

    match /invoice_counter/{gymId} {
      allow read, write: if request.auth != null
        && request.auth.token.gym_id == gymId;
    }

    // Phase 4: Attendance Logs — gym-isolated (H-4)
    match /attendance_logs/{logId} {
      allow read: if request.auth != null
        && request.auth.token.gym_id
           == resource.data.gym_id;
      allow create: if request.auth != null
        && request.resource.data.gym_id
           == request.auth.token.gym_id;
      allow update, delete: if request.auth != null
        && resource.data.gym_id
           == request.auth.token.gym_id;
    }

    // Phase 4: WhatsApp Logs — gym-isolated (H-4)
    match /whatsapp_logs/{logId} {
      allow read: if request.auth != null
        && request.auth.token.gym_id
           == resource.data.gym_id;
      allow create: if request.auth != null
        && request.resource.data.gym_id
           == request.auth.token.gym_id;
      allow update, delete: if request.auth != null
        && resource.data.gym_id
           == request.auth.token.gym_id;
    }

    // Phase 5: Message Retry Queue — gym-isolated (H-4)
    match /message_retry_queue/{docId} {
      allow read: if request.auth != null
        && request.auth.token.gym_id
           == resource.data.gym_id;
      allow create: if request.auth != null
        && request.resource.data.gym_id
           == request.auth.token.gym_id;
      allow update, delete: if request.auth != null
        && resource.data.gym_id
           == request.auth.token.gym_id;
    }

    // Phase 5: Message Logs — gym-isolated (H-4)
    match /message_logs/{logId} {
      allow read: if request.auth != null
        && request.auth.token.gym_id
           == resource.data.gym_id;
      allow create: if request.auth != null
        && request.resource.data.gym_id
           == request.auth.token.gym_id;
      allow update, delete: if request.auth != null
        && resource.data.gym_id
           == request.auth.token.gym_id;
    }

    // Phase 6: Invoices — gym-isolated (H-4)
    match /invoices/{invoiceId} {
      allow read: if request.auth != null
        && request.auth.token.gym_id
           == resource.data.gym_id;
      allow create: if request.auth != null
        && request.resource.data.gym_id
           == request.auth.token.gym_id;
      allow update, delete: if request.auth != null
        && resource.data.gym_id
           == request.auth.token.gym_id;
    }

    // Subscription System
    match /subscriptions/{gymId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.token.role == 'admin'
            || get(/databases/$(database)/documents/gyms/$(gymId)).data.owner_id == request.auth.uid);
    }

    match /billing/{gymId}/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.token.role == 'admin'
            || get(/databases/$(database)/documents/gyms/$(gymId)).data.owner_id == request.auth.uid);
    }

    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }

    match /admin_logs/{logId} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow create: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow update, delete: if false;
    }

    // Member Numbering System — gym-isolated (H-4)
    match /numbering_settings/{gymId} {
      allow read, write: if request.auth != null
        && request.auth.token.gym_id == gymId;
    }

    // Serial counters docId is {gymId}_{counterKey}; gymId field stored in doc (H-4)
    match /serial_counters/{docId} {
      allow read: if request.auth != null
        && request.auth.token.gym_id
           == resource.data.gymId;
      allow create: if request.auth != null
        && request.resource.data.gymId
           == request.auth.token.gym_id;
      allow update, delete: if request.auth != null
        && resource.data.gymId
           == request.auth.token.gym_id;
    }

    // Coupon Activation — owners can read; all writes go through redeemCoupon Cloud Function
    match /used_coupons/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Kiosk Devices — auth required to read; unauthenticated update only via device_secret (H-5)
    match /kiosk_devices/{deviceId} {
      allow read: if request.auth != null;
      allow update: if request.resource.data.device_secret == resource.data.device_secret;
      allow create, delete: if request.auth != null
        && request.auth.token.role
           in ['owner', 'manager'];
    }

    // Attendance Sessions — kiosk creates via device_secret validation; owners read by gym (H-5)
    match /attendance_sessions/{sessionId} {
      allow create: if request.resource.data.device_secret
        == get(/databases/$(database)/documents/kiosk_devices/$(request.resource.data.device_id))
           .data.device_secret;
      allow read: if request.auth != null
        && request.auth.token.gym_id
           == resource.data.gym_id;
      allow update, delete: if false;
    }

    // Access Denied Logs — kiosk writes, owners read
    match /access_denied_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if true;
    }

    // Coupons — server-only; never readable or writable by clients
    match /coupons/{code} {
      allow read, write: if false;
    }

    // Recycle bin — owner and manager in same gym can read; all writes server-only
    match /deleted_members/{gymId}/bin/{memberId} {
      allow read: if request.auth != null
        && request.auth.token.gym_id == gymId
        && request.auth.token.role
           in ['owner', 'manager'];
      allow write: if false;
    }

    // Audit log — owner and manager read only; completely server-side writes
    match /audit_logs/{gymId}/events/{eventId} {
      allow read: if request.auth != null
        && request.auth.token.gym_id == gymId
        && request.auth.token.role
           in ['owner', 'manager'];
      allow write: if false;
    }
  }
}
