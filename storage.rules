rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Agreement PDFs — members can write their own
    match /agreements/{gymId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Phase 4: Invoice storage & Payment Screenshots
    match /gyms/{gymId}/invoices/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /payment_screenshots/{paymentId} {
      allow read, write: if request.auth != null;
    }
    
    // Gym photos
    match /gyms/{gymId}/photos/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Default fallback (lockdown for safety)
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
